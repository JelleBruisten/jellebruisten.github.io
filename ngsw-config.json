{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "shaders",
      "installMode": "lazy",
      "resources": {
        "files": [
          "/shaders/*.glsl",
          "/shaders/*.wgsl"
        ]
      }
    },
    {
      "name": "blog-content",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/content/blog/*.json"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ]
}
